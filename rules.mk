# Firmware size is tight on the Moonlander — keep only what you use.

MOUSEKEY_ENABLE  = no   # Mouse emulation via keyboard
EXTRAKEY_ENABLE  = yes  # Media & system keys (volume, brightness)
CONSOLE_ENABLE   = no   # Debug console
COMMAND_ENABLE   = no   # Legacy debug commands
NKRO_ENABLE      = yes  # N-Key Rollover (all keys register simultaneously)
